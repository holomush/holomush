{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "schedule": ["before 9am on monday"],
  "timezone": "America/New_York",
  "labels": ["dependencies", "renovate-bot"],
  "platformAutomerge": true,
  "gomod": {
    "managerFilePatterns": [
      "/(^|/)go\\.mod$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track web/buf.gen.yaml BSR codegen plugin pins via their inline `# renovate:` annotations",
      "managerFilePatterns": [
        "/(^|/)web/buf\\.gen\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+- remote: [^:\\s]+:v(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge minor/patch Go deps",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "addLabels": ["go"]
    },
    {
      "description": "Auto-merge GitHub Actions (minor/patch/digest)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "groupName": "GitHub Actions",
      "addLabels": ["github-actions"]
    },
    {
      "description": "Auto-merge Docker minor/patch/digest",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "addLabels": ["docker"]
    },
    {
      "description": "Batch all non-major npm/pnpm bumps into a single PR",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm dependencies",
      "automerge": true,
      "addLabels": ["npm"]
    },
    {
      "description": "Group OpenTelemetry packages",
      "groupName": "OpenTelemetry",
      "matchPackageNames": [
        "go.opentelemetry.io/otel{/,}**"
      ]
    },
    {
      "description": "Group pgx packages",
      "groupName": "pgx",
      "matchPackageNames": [
        "github.com/jackc/pgx{/,}**"
      ]
    },
    {
      "description": "Group testify packages",
      "groupName": "testify",
      "matchPackageNames": [
        "github.com/stretchr/testify{/,}**"
      ]
    },
    {
      "description": "Group golang.org/x packages",
      "groupName": "golang.org/x",
      "matchPackageNames": [
        "golang.org/x/{/,}**"
      ]
    },
    {
      "description": "Group Google packages (grpc, protobuf)",
      "groupName": "Google Go",
      "matchPackageNames": [
        "google.golang.org/{/,}**"
      ]
    },
    {
      "description": "NATS packages — extra stabilization time, grouped, weekly schedule",
      "matchPackageNames": [
        "github.com/nats-io/nats-server/v2",
        "github.com/nats-io/nats.go"
      ],
      "minimumReleaseAge": "14 days",
      "groupName": "nats",
      "schedule": ["after 9am on Monday"]
    },
    {
      "description": "Major version bumps require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update"]
    },
    {
      "description": "Group the web/buf.gen.yaml bufbuild/es pin with its @bufbuild/protoc-gen-es web/package.json devDependency so they bump together in one PR. Not auto-merged — a pin bump doesn't regenerate the committed _pb.ts stubs, so a human runs `task web:generate` on the bump PR (holomush-ai3o5).",
      "matchPackageNames": [
        "@bufbuild/protoc-gen-es"
      ],
      "groupName": "buf codegen",
      "automerge": false,
      "addLabels": ["codegen", "web"]
    }
  ],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
  "commitMessagePrefix": "deps:",
  "commitMessageAction": "bump"
}
