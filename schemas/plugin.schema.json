{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://holomush.dev/schemas/plugin.schema.json",
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "setting"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "not": {
          "required": [
            "emits"
          ]
        }
      }
    }
  ],
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^[a-z](-?[a-z0-9])*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "lua",
        "binary",
        "setting"
      ]
    },
    "engine": {
      "type": "string",
      "description": "HoloMUSH version constraint (e.g. \u003e= 2.0.0)"
    },
    "dependencies": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object",
      "description": "Plugin dependencies with version constraints"
    },
    "events": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "emits": {
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z](-?[a-z0-9])*$"
      },
      "type": "array",
      "uniqueItems": true
    },
    "actor_kinds_claimable": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "policies": {
      "items": {
        "properties": {
          "name": {
            "type": "string"
          },
          "dsl": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "name",
          "dsl"
        ]
      },
      "type": "array"
    },
    "commands": {
      "items": {
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "aliases": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "capabilities": {
            "items": {
              "properties": {
                "action": {
                  "type": "string"
                },
                "resource": {
                  "type": "string"
                },
                "scope": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "type": "object",
              "required": [
                "action",
                "resource"
              ]
            },
            "type": "array"
          },
          "help": {
            "type": "string"
          },
          "usage": {
            "type": "string"
          },
          "helpText": {
            "type": "string"
          },
          "helpFile": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "name"
        ]
      },
      "type": "array",
      "description": "Commands provided by this plugin"
    },
    "verbs": {
      "items": {
        "properties": {
          "type": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "display_target": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "type",
          "category",
          "format",
          "display_target"
        ]
      },
      "type": "array",
      "description": "Verb registrations contributed by this plugin"
    },
    "priority": {
      "type": "integer",
      "description": "Load priority (lower loads first)"
    },
    "session_streams": {
      "type": "boolean",
      "description": "Plugin contributes streams to session subscriptions via QuerySessionStreams"
    },
    "lua-plugin": {
      "properties": {
        "entry": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "entry"
      ]
    },
    "binary-plugin": {
      "properties": {
        "executable": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "executable"
      ]
    },
    "setting": {
      "properties": {
        "display_name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "content_dir": {
          "type": "string"
        },
        "world_dir": {
          "type": "string"
        },
        "theme": {
          "type": "string"
        },
        "starting_location": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "display_name",
        "description",
        "content_dir",
        "world_dir",
        "theme",
        "starting_location"
      ]
    },
    "requires": {
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "oneOf": [
              {
                "required": [
                  "capability"
                ]
              },
              {
                "required": [
                  "service"
                ]
              }
            ],
            "properties": {
              "capability": {
                "type": "string"
              },
              "service": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "optional": {
                "type": "boolean"
              },
              "scope": {
                "type": "string"
              },
              "access": {
                "type": "string"
              }
            },
            "additionalProperties": false,
            "type": "object"
          }
        ]
      },
      "type": "array"
    },
    "provides": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "storage": {
      "type": "string"
    },
    "crypto": {
      "properties": {
        "emits": {
          "items": {
            "properties": {
              "event_type": {
                "type": "string"
              },
              "sensitivity": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "readback": {
                "type": "boolean"
              }
            },
            "additionalProperties": false,
            "type": "object",
            "required": [
              "event_type",
              "sensitivity"
            ]
          },
          "type": "array"
        },
        "consumes": {
          "items": {
            "properties": {
              "subjects": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "requests_decryption": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            },
            "additionalProperties": false,
            "type": "object",
            "required": [
              "subjects"
            ]
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "config": {
      "additionalProperties": {
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "duration",
              "int",
              "bool",
              "string"
            ]
          },
          "default": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "type"
        ]
      },
      "type": "object"
    },
    "audit": {
      "items": {
        "properties": {
          "subjects": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "schema": {
            "type": "string"
          },
          "table": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "subjects"
        ]
      },
      "type": "array"
    },
    "history_scope": {
      "type": "string"
    },
    "resource_types": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "actions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "trust": {
      "properties": {
        "all_principals": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "all_principals"
      ]
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "name",
    "version",
    "type"
  ],
  "title": "HoloMUSH Plugin Manifest",
  "description": "Schema for plugin.yaml manifest files"
}
