# yamlfmt configuration
# https://github.com/google/yamlfmt

formatter:
  type: basic
  indent: 2
  max_line_length: 120
  include_document_start: false
  retain_line_breaks: true
  trim_trailing_whitespace: true
  eof_newline: true
  pad_line_comments: 1

exclude:
  - .serena/
  - dist/
  - .worktrees/
  - .claude/worktrees/
  - node_modules/
  - web/node_modules/
  - site/node_modules/ # bun deps for the Astro docs site
  - site/dist/ # Astro build output
  - vendor/
  - web/pnpm-lock.yaml # generated by pnpm, not human-edited
